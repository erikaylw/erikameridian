# CrewAI — Environment Variables
# Pilih SALAH SATU provider. Uncomment baris yang lo pake.

# Opsi 1: DeepSeek (recommended — murah & powerful)
# Daftar: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-xxxx

# Opsi 2: OpenAI
# OPENAI_API_KEY=sk-xxxx

# Opsi 3: OpenRouter (akses GPT, Claude, Gemini, dll)
# OPENROUTER_API_KEY=sk-or-xxxx
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Opsional: Serper untuk web search (gratis 2500 queries)
# Kalo ga diisi, pake DuckDuckGo bawaan (gratis, no limit)
# SERPER_API_KEY=xxxx
